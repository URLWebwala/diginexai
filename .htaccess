<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Prevent directory listing
Options -Indexes

# Handle index.php
RewriteRule ^index\.php$ - [L]

# Pretty URLs for core pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^about/?$ about.php [L,NC]
RewriteRule ^service/?$ service.php [L,NC]
RewriteRule ^blog/?$ blog.php [L,NC]
RewriteRule ^contact/?$ contact.php [L,NC]

# Blog detail pretty URL: /blog/your-slug
RewriteRule ^blog/([^/]+)/?$ blogdetailpage.php?slug=$1 [L,QSA,NC]

# Generic fallback for index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
